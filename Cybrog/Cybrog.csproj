<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>Cybrog</RootNamespace>
    <AssemblyName>Cybrog</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <LangVersion>latest</LangVersion>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <Authors>Botshelo</Authors>
    <Product>Cybrog - Cybersecurity Companion</Product>
    <Description>WPF cybersecurity education chatbot — IIE Part 3 POE submission.</Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- Microsoft SQL Server client (LocalDB / SQL Express / full SQL Server) -->
    <PackageReference Include="Microsoft.Data.SqlClient" Version="5.2.2" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Resources\" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Resources\Greeting AI .wav">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>

<Window x:Class="Cybrog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Cybrog.Converters"
        Title="Cybrog — Your Cybersecurity Companion"
        Height="780" Width="1280" MinHeight="600" MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushPageBg}"
        FontFamily="{StaticResource FontBody}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:CountToVisibilityConverter x:Key="CountToVis"/>
        <conv:SenderToAlignmentConverter x:Key="SenderToAlign"/>
        <conv:SenderToBrushConverter x:Key="SenderToBrush"/>
        <conv:HexToBrushConverter x:Key="HexToBrush"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:BoolToStrikethroughConverter x:Key="BoolToStrike"/>

        <!-- Style to remove ListBox selection visuals for chat -->
        <Style x:Key="ChatListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════ LEFT NAV ═══════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource BrushWhite}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,1,0">
            <DockPanel Margin="16">
                <StackPanel DockPanel.Dock="Top">
                    <!-- Brand -->
                    <StackPanel Orientation="Horizontal" Margin="4,4,4,22">
                        <Border Width="38" Height="38" CornerRadius="19" Background="{StaticResource BrushYellow}">
                            <TextBlock Text="🤖" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Cybrog" Style="{StaticResource TextHeading}" FontSize="17"/>
                            <TextBlock Text="Cybersecurity Companion" Style="{StaticResource TextCaption}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Online status -->
                    <Border Background="{StaticResource BrushYellowPale}" CornerRadius="10" Padding="12,9" Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource BrushSuccess}" VerticalAlignment="Center"/>
                            <TextBlock Text="Online — Ready to help" Margin="8,0,0,0" FontSize="12" Foreground="{StaticResource BrushTextPrimary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Nav tabs -->
                    <RadioButton x:Name="NavChat" Style="{StaticResource NavTabButton}" GroupName="Nav" IsChecked="True" Checked="NavTab_Checked" Tag="Chat"
                                 AutomationProperties.Name="Chat">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💬" Margin="0,0,10,0"/>
                            <TextBlock Text="Chat" FontWeight="Medium"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavTopics" Style="{StaticResource NavTabButton}" GroupName="Nav" Checked="NavTab_Checked" Tag="Topics" Margin="0,4,0,0"
                                 AutomationProperties.Name="Topics">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📚" Margin="0,0,10,0"/>
                            <TextBlock Text="Topics"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavTasks" Style="{StaticResource NavTabButton}" GroupName="Nav" Checked="NavTab_Checked" Tag="Tasks" Margin="0,4,0,0"
                                 AutomationProperties.Name="My Tasks">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Margin="0,0,10,0"/>
                            <TextBlock Text="My Tasks"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavQuiz" Style="{StaticResource NavTabButton}" GroupName="Nav" Checked="NavTab_Checked" Tag="Quiz" Margin="0,4,0,0"
                                 AutomationProperties.Name="Mini-Game Quiz">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎮" Margin="0,0,10,0"/>
                            <TextBlock Text="Mini-Game (Quiz)"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Footer card -->
                <Border DockPanel.Dock="Bottom" Background="{StaticResource BrushYellowPale}" CornerRadius="{StaticResource RadiusCard}" Padding="14" Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Text="🛡️" FontSize="22" HorizontalAlignment="Center"/>
                        <TextBlock Text="Be Aware, Be Secure" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,2" TextAlignment="Center"/>
                        <TextBlock Text="Small steps today, safer tomorrow." Style="{StaticResource TextCaption}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Grid/>
            </DockPanel>
        </Border>

        <!-- ═══════════════════ CENTER CONTENT ═══════════════════ -->
        <Grid Grid.Column="1" Margin="20">

            <!-- ── CHAT VIEW ── -->
            <Grid x:Name="ChatView" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,14" Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="GreetingText" Text="Hello!" Style="{StaticResource TextHeading}" FontSize="19"/>
                            <TextBlock Text="What would you like to learn about today?" Style="{StaticResource TextSubtle}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Clear Chat" Style="{StaticResource SecondaryButton}" Click="ClearChat_Click"
                                AutomationProperties.Name="Clear Chat"/>
                    </Grid>
                </Border>

                <!-- Messages – virtualized ListBox -->
                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0" Margin="0,0,0,14">
                    <ListBox x:Name="ChatItems"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource ChatListBoxItemStyle}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel VirtualizationMode="Recycling"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,14" HorizontalAlignment="{Binding Sender, Converter={StaticResource SenderToAlign}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="30" Height="30" CornerRadius="15" Background="{StaticResource BrushYellow}"
                                            VerticalAlignment="Top" Margin="0,0,8,0"
                                            Visibility="{Binding IsUser, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                                        <TextBlock Text="🤖" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Grid.Column="1" MaxWidth="560" CornerRadius="{StaticResource RadiusBubble}" Padding="14,10"
                                            Background="{Binding Sender, Converter={StaticResource SenderToBrush}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="13.5" Foreground="{StaticResource BrushTextPrimary}" LineHeight="20"/>
                                            <TextBlock Text="{Binding TimeLabel}" Style="{StaticResource TextCaption}" Margin="0,5,0,0" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- Input row -->
                <Grid Grid.Row="2" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ChatInput" Style="{StaticResource ChatInputBox}" Grid.Column="0"
                             KeyDown="ChatInput_KeyDown" Text="Please enter your message..." Margin="0,0,10,0"
                             AutomationProperties.HelpText="Type your message here"/>
                    <Button Grid.Column="1" Width="44" Height="44" Style="{StaticResource PrimaryButton}" Click="SendButton_Click"
                            AutomationProperties.Name="Send message">
                        <TextBlock Text="SEND" FontSize="16"/>
                    </Button>
                </Grid>

                <!-- Quick topics -->
                <StackPanel Grid.Row="3">
                    <TextBlock Text="Explore Topics" Style="{StaticResource TextSubtle}" FontWeight="SemiBold" Margin="2,0,0,8"/>
                    <WrapPanel x:Name="QuickTopicsPanel"/>
                </StackPanel>
            </Grid>

            <!-- ── TOPICS VIEW ── -->
            <Grid x:Name="TopicsView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Cybersecurity Topics" Style="{StaticResource TextHeading}" FontSize="20" Margin="2,0,0,16"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="TopicsItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}" Width="280" Height="190" Margin="0,0,16,16" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Icon}" FontSize="28" Margin="0,0,0,10"/>
                                        <TextBlock Text="{Binding DisplayName}" Style="{StaticResource TextHeading}" FontSize="15" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding Scenario}" Style="{StaticResource TextSubtle}" TextTrimming="CharacterEllipsis" MaxHeight="60" TextWrapping="Wrap"/>
                                        <Button Content="Learn more →" Style="{StaticResource SecondaryButton}" Margin="0,14,0,0"
                                                HorizontalAlignment="Left" Tag="{Binding Key}" Click="TopicCard_Click"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ── TASKS VIEW ── -->
            <Grid x:Name="TasksView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="2,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="My Tasks" Style="{StaticResource TextHeading}" FontSize="20"/>
                    <TextBlock Grid.Column="1" x:Name="DbStatusText" Text="" Style="{StaticResource TextCaption}" VerticalAlignment="Center"/>
                </Grid>

                <!-- Add task form -->
                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,14,0,14" Padding="16">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="NewTaskTitle" Style="{StaticResource FormInputBox}" Grid.Column="0" Margin="0,0,10,0"
                                     AutomationProperties.HelpText="Task title, e.g. Enable two-factor authentication"/>
                            <DatePicker x:Name="NewTaskReminder" Grid.Column="1" Margin="0,0,10,0"/>
                            <Button Grid.Column="2" Content="+ Add Task" Style="{StaticResource PrimaryButton}" Click="AddTask_Click"
                                    AutomationProperties.Name="Add Task"/>
                        </Grid>
                        <TextBox x:Name="NewTaskDescription" Style="{StaticResource FormInputBox}"
                                 AutomationProperties.HelpText="Optional description, e.g. Review account privacy settings"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="NoTasksText" Text="No tasks yet — add your first cybersecurity task above." Style="{StaticResource TextSubtle}"
                                   HorizontalAlignment="Center" Margin="0,40,0,0" Visibility="Visible"/>
                        <ItemsControl x:Name="TasksItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10" Padding="16,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                                      Checked="TaskCheck_Changed" Unchecked="TaskCheck_Changed"
                                                      Tag="{Binding Id}" VerticalAlignment="Center" Margin="0,0,12,0"/>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontWeight="Medium" FontSize="13.5"
                                                           TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToStrike}}"/>
                                                <TextBlock Text="{Binding Description}" Style="{StaticResource TextSubtle}" Margin="0,2,0,0"
                                                           TextWrapping="Wrap" Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Text="{Binding ReminderLabel}" Style="{StaticResource TextCaption}" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <Border Grid.Column="2" CornerRadius="{StaticResource RadiusPill}" Padding="10,4" Margin="0,0,10,0"
                                                    Background="{StaticResource BrushYellowSoft}">
                                                <TextBlock Text="{Binding StatusLabel}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{Binding StatusColor, Converter={StaticResource HexToBrush}}"/>
                                            </Border>

                                            <Button Grid.Column="3" Content="✕" Width="28" Height="28" Style="{StaticResource SecondaryButton}"
                                                    Padding="0" Tag="{Binding Id}" Click="DeleteTask_Click"
                                                    AutomationProperties.Name="Delete task"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── QUIZ VIEW ── -->
            <Grid x:Name="QuizView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Mini-Game — Cybersecurity Quiz" Style="{StaticResource TextHeading}" FontSize="20" Margin="2,0,0,16"/>

                <Grid Grid.Row="1">
                    <!-- Quiz intro -->
                    <Border x:Name="QuizIntroCard" Style="{StaticResource CardBorder}" MaxWidth="460" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="32">
                        <StackPanel>
                            <TextBlock Text="🏆" FontSize="44" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                            <TextBlock Text="Test your cybersecurity knowledge!" Style="{StaticResource TextHeading}" FontSize="16" HorizontalAlignment="Center" TextAlignment="Center"/>
                            <TextBlock Text="15 questions covering phishing, passwords, malware, safe browsing and more." Style="{StaticResource TextSubtle}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,20" TextWrapping="Wrap"/>
                            <TextBlock x:Name="BestScoreText" Text="" Style="{StaticResource TextSubtle}" HorizontalAlignment="Center" Margin="0,0,0,16" FontWeight="SemiBold"/>
                            <Button Content="🎮 Start Quiz" Style="{StaticResource PrimaryButton}" Click="StartQuiz_Click" HorizontalAlignment="Center" Padding="24,12"
                                    AutomationProperties.Name="Start Quiz"/>
                        </StackPanel>
                    </Border>

                    <!-- Active question -->
                    <Border x:Name="QuizActiveCard" Style="{StaticResource CardBorder}" MaxWidth="560" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Padding="28" Visibility="Collapsed"
                            Focusable="True" KeyDown="QuizActiveCard_KeyDown">
                        <StackPanel>
                            <!-- Header: progress, score, exit button -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="QuizProgressText" Text="Question 1/15" Style="{StaticResource TextSubtle}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" x:Name="QuizScoreText" Text="Score: 0" Style="{StaticResource TextSubtle}" FontWeight="SemiBold" Margin="0,0,12,0"/>
                                <Button Grid.Column="2" Content="✕ Exit" Style="{StaticResource SecondaryButton}" Padding="8,4" FontSize="11"
                                        Click="ExitQuiz_Click" AutomationProperties.Name="Exit Quiz" ToolTip="Exit quiz"/>
                            </Grid>

                            <TextBlock x:Name="QuizQuestionText" Text="Question text" FontSize="16" FontWeight="Medium" TextWrapping="Wrap" Margin="0,0,0,18"/>
                            <StackPanel x:Name="QuizOptionsPanel"/>
                            <Border x:Name="QuizFeedbackBox" Visibility="Collapsed" CornerRadius="10" Padding="14" Margin="0,14,0,0">
                                <TextBlock x:Name="QuizFeedbackText" TextWrapping="Wrap" FontSize="12.5"/>
                            </Border>
                            <Button x:Name="QuizNextButton" Content="Next Question →" Style="{StaticResource PrimaryButton}" Margin="0,16,0,0"
                                    HorizontalAlignment="Right" Visibility="Collapsed" Click="QuizNext_Click"
                                    AutomationProperties.Name="Next Question"/>
                        </StackPanel>
                    </Border>

                    <!-- Results -->
                    <Border x:Name="QuizResultsCard" Style="{StaticResource CardBorder}" MaxWidth="460" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="32" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="ResultsEmoji" Text="🎉" FontSize="44" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                            <TextBlock Text="Quiz Complete!" Style="{StaticResource TextHeading}" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="ResultsScoreText" Text="8/15" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,4" Foreground="{StaticResource BrushYellowDeep}"/>
                            <TextBlock x:Name="ResultsMessageText" Text="" Style="{StaticResource TextSubtle}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,4,0,20" TextWrapping="Wrap"/>
                            <Button Content="Try Again" Style="{StaticResource PrimaryButton}" Click="StartQuiz_Click" HorizontalAlignment="Center" Padding="24,12"
                                    AutomationProperties.Name="Try Quiz Again"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══════════════════ RIGHT SIDEBAR — MY MEMORY ═══════════════════ -->
        <Border Grid.Column="2" Background="{StaticResource BrushWhite}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18">
                <StackPanel>

                    <!-- Clock -->
                    <Border Background="{StaticResource BrushYellowPale}" CornerRadius="{StaticResource RadiusCard}" Padding="14" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🕐" FontSize="18" VerticalAlignment="Center"/>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock x:Name="ClockText" Text="--:--:--" FontWeight="Bold" FontSize="15"/>
                                <TextBlock x:Name="DateText" Text="" Style="{StaticResource TextCaption}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- My Memory card -->
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="🧠 My Memory" Style="{StaticResource TextHeading}" FontSize="15" Margin="0,0,0,12"/>

                            <TextBlock Text="Name" Style="{StaticResource TextCaption}"/>
                            <TextBlock x:Name="MemNameText" Text="Not shared yet" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource BrushYellowDeep}" Margin="0,1,0,10"/>

                            <TextBlock Text="Favourite Topic" Style="{StaticResource TextCaption}"/>
                            <TextBlock x:Name="MemFavouriteText" Text="—" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource BrushYellowDeep}" Margin="0,1,0,10"/>

                            <TextBlock Text="Last Topic" Style="{StaticResource TextCaption}"/>
                            <TextBlock x:Name="MemLastTopicText" Text="—" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource BrushYellowDeep}" Margin="0,1,0,10"/>

                            <TextBlock Text="Total Interactions" Style="{StaticResource TextCaption}"/>
                            <TextBlock x:Name="MemInteractionsText" Text="0" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource BrushYellowDeep}" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Quiz best score -->
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="🏆 Mini-Game" Style="{StaticResource TextHeading}" FontSize="15" Margin="0,0,0,8"/>
                            <TextBlock x:Name="SidebarBestScoreText" Text="No attempts yet" Style="{StaticResource TextSubtle}" Margin="0,0,0,10"/>
                            <Button Content="Start Quiz" Style="{StaticResource SecondaryButton}" Click="GoToQuiz_Click" HorizontalAlignment="Stretch"
                                    AutomationProperties.Name="Start Quiz from sidebar"/>
                        </StackPanel>
                    </Border>

                    <!-- Activity log -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="📝 Activity Log" Style="{StaticResource TextHeading}" FontSize="15"/>
                                <Button x:Name="ToggleLogButton" Grid.Column="1" Content="Show more" Style="{StaticResource SecondaryButton}"
                                        Padding="8,4" FontSize="11" Click="ToggleActivityLog_Click"
                                        AutomationProperties.Name="Toggle activity log"/>
                            </Grid>
                            <ItemsControl x:Name="ActivityLogItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,9">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Time}" Style="{StaticResource TextCaption}" Width="42" VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Action}" FontSize="11.5" TextWrapping="Wrap" Foreground="{StaticResource BrushTextPrimary}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="NoActivityText" Text="No activity yet — start chatting!" Style="{StaticResource TextCaption}" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
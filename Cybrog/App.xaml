<Application x:Class="Cybrog.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- ════════════════════════════════════════════════════════════
                 DESIGN TOKENS — strict white / yellow / light-grey palette.
                 No dark UI elements anywhere, per the assignment brief.
                 ════════════════════════════════════════════════════════════ -->

            <!-- Core palette -->
            <SolidColorBrush x:Key="BrushWhite" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="BrushPageBg" Color="#FAFAF7"/>
            <SolidColorBrush x:Key="BrushCardBg" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="BrushLightGrey" Color="#F2F1EC"/>
            <SolidColorBrush x:Key="BrushMidGrey" Color="#E5E3DA"/>
            <SolidColorBrush x:Key="BrushBorder" Color="#EAE8E0"/>

            <!-- Yellow accent family -->
            <SolidColorBrush x:Key="BrushYellow" Color="#F6C90E"/>
            <SolidColorBrush x:Key="BrushYellowDeep" Color="#E0AE00"/>
            <SolidColorBrush x:Key="BrushYellowSoft" Color="#FDF0C0"/>
            <SolidColorBrush x:Key="BrushYellowPale" Color="#FFFBEA"/>

            <!-- Text (warm charcoal — not pure black, stays within a light, soft system) -->
            <SolidColorBrush x:Key="BrushTextPrimary" Color="#2B2A26"/>
            <SolidColorBrush x:Key="BrushTextSecondary" Color="#73716A"/>
            <SolidColorBrush x:Key="BrushTextMuted" Color="#A6A399"/>

            <!-- Functional accents (kept desaturated/pastel to respect the light-only rule) -->
            <SolidColorBrush x:Key="BrushSuccess" Color="#2E7D32"/>
            <SolidColorBrush x:Key="BrushSuccessSoft" Color="#E8F5E9"/>
            <SolidColorBrush x:Key="BrushWarn" Color="#B45309"/>
            <SolidColorBrush x:Key="BrushWarnSoft" Color="#FFF3E0"/>
            <SolidColorBrush x:Key="BrushDanger" Color="#B3261E"/>
            <SolidColorBrush x:Key="BrushDangerSoft" Color="#FDECEA"/>

            <!-- ── Typography ─────────────────────────────────────────────── -->
            <FontFamily x:Key="FontDisplay">Segoe UI Semibold</FontFamily>
            <FontFamily x:Key="FontBody">Segoe UI</FontFamily>

            <!-- ── Corner radii (soft, rounded — matches reference mockups) ── -->
            <CornerRadius x:Key="RadiusCard">14</CornerRadius>
            <CornerRadius x:Key="RadiusBubble">16</CornerRadius>
            <CornerRadius x:Key="RadiusPill">20</CornerRadius>
            <CornerRadius x:Key="RadiusButton">10</CornerRadius>

            <!-- ════════════════════════════════════════════════════════════
                 STYLES
                 ════════════════════════════════════════════════════════════ -->

            <!-- Base text style -->
            <Style x:Key="TextBase" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="TextHeading" TargetType="TextBlock" BasedOn="{StaticResource TextBase}">
                <Setter Property="FontFamily" Value="{StaticResource FontDisplay}"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="TextSubtle" TargetType="TextBlock" BasedOn="{StaticResource TextBase}">
                <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <Style x:Key="TextCaption" TargetType="TextBlock" BasedOn="{StaticResource TextBase}">
                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
                <Setter Property="FontSize" Value="11"/>
            </Style>

            <!-- Card container -->
            <Style x:Key="CardBorder" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource BrushCardBg}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="{StaticResource RadiusCard}"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#1A1A1A" Opacity="0.05" BlurRadius="14" ShadowDepth="2" Direction="270"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Primary CTA button — solid yellow -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource BrushYellow}"/>
                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                <Setter Property="FontFamily" Value="{StaticResource FontDisplay}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource RadiusButton}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushYellowDeep}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushMidGrey}"/>
                                    <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Secondary / outline button -->
            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource BrushWhite}"/>
                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="14,9"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource BrushYellowDeep}" BorderThickness="1.5"
                                    CornerRadius="{StaticResource RadiusButton}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushYellowPale}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Quick-topic pill button -->
            <Style x:Key="PillButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource BrushLightGrey}"/>
                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
                <Setter Property="FontSize" Value="12.5"/>
                <Setter Property="Padding" Value="14,8"/>
                <Setter Property="Margin" Value="0,0,8,8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource RadiusPill}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushYellowSoft}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Left nav tab button -->
            <Style x:Key="NavTabButton" TargetType="RadioButton">
                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="14,11"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="{StaticResource RadiusButton}">
                                <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushYellow}"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsChecked" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushLightGrey}"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Chat input textbox -->
            <Style x:Key="ChatInputBox" TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource BrushLightGrey}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="14,10"/>
                <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
                <Setter Property="FontSize" Value="13.5"/>
                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                <Setter Property="CaretBrush" Value="{StaticResource BrushTextPrimary}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusPill}">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Generic flat TextBox (forms: add task, etc.) -->
            <Style x:Key="FormInputBox" TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource BrushLightGrey}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ScrollViewer with a thin unobtrusive scrollbar -->
            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="8"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid>
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="{StaticResource BrushMidGrey}" CornerRadius="4" Width="6" Margin="1"/>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
